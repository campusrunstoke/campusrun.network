# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# ---------------------------------------------------------------------------

# --- Database (Postgres) ---
# Local dev: points at the docker-compose Postgres on host port 5439 (a high port
# chosen so it never collides with any other local Postgres you have running).
# Production (Vercel): use the Neon POOLED connection string (…-pooler.neon.tech).
DATABASE_URL="postgres://campusrun:campusrun@localhost:5439/campusrun"

# --- Admin ---
# Admins are real accounts in the database (argon2-hashed passwords), not an env var.
# Create one with:  npm run admin:create
# (no admin secrets live here anymore)

# --- Rate limiting on the public /api/submit endpoint ---
RATE_LIMIT_MAX="20"
RATE_LIMIT_WINDOW_SECONDS="60"

# --- Bot protection (optional, OFF by default) ---
# Cloudflare Turnstile. Leave both blank to disable. Fill both to enable.
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
