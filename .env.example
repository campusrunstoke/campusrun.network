# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# ---------------------------------------------------------------------------

# --- Database (Postgres) ---
# Local dev: points at the docker-compose Postgres on host port 5439 (a high port
# chosen so it never collides with any other local Postgres you have running).
# Production (Vercel): use the Neon POOLED connection string (…-pooler.neon.tech).
DATABASE_URL="postgres://campusrun:campusrun@localhost:5439/campusrun"

# --- Admin ---
# Admins are real accounts in the database (argon2-hashed passwords), not an env var.
# Create one with:  npm run admin:create
# (no admin secrets live here anymore)

# --- Site URL used in generated NFC links (the pretty domain) ---
NEXT_PUBLIC_SITE_URL="https://campusrun.network"

# --- Rate limiting on the public /api/submit endpoint ---
RATE_LIMIT_MAX="20"
RATE_LIMIT_WINDOW_SECONDS="60"

# --- Intake form (/work-with-us) ---
LEAD_RATE_LIMIT_MAX="5"
LEAD_RATE_LIMIT_WINDOW_SECONDS="600"

# --- New-inquiry email notification (optional, OFF until filled in) ---
# Plain SMTP — no paid service. Use the mailbox you already own:
#   Namecheap Private Email → host mail.privateemail.com, port 465
#   Google Workspace / Gmail → host smtp.gmail.com, port 465, pass = an App Password
# Leave SMTP_HOST blank to disable (inquiries are still saved and shown in /admin/leads).
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""            # the full mailbox address that sends the notification
SMTP_PASS=""            # mailbox password / app password — NEVER commit a real value
LEAD_NOTIFY_FROM=""     # optional; defaults to SMTP_USER
LEAD_NOTIFY_TO=""       # comma-separated recipients, e.g. "kasey@…,brandon@…"

# --- Bot protection (optional, OFF by default) ---
# Cloudflare Turnstile. Leave both blank to disable. Fill both to enable.
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
